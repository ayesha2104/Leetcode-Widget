# Copy to .env and adjust as needed. All values have safe defaults in
# codepulse.infrastructure.config.settings.AppSettings — this file only
# documents what can be overridden per environment.

# Overrides log verbosity: TRACE, DEBUG, INFO, WARNING, ERROR
CODEPULSE_LOG_LEVEL=INFO

# Root directory for the SQLite database, JSON cache, and log files.
# Defaults to the platform user-data directory when unset.
CODEPULSE_DATA_DIR=

# Network timeout (seconds) for provider API requests.
CODEPULSE_HTTP_TIMEOUT=10
